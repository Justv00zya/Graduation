@page "/ForgotPassword"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using OrgTechRepair.Services
@inject NavigationManager Navigation
@inject UserManager<IdentityUser> UserManager
@inject IEmailSender EmailSender
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Восстановление пароля</PageTitle>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card">
                <div class="card-header">
                    <h3 class="text-center">Восстановление пароля</h3>
                </div>
                <div class="card-body">
                    @if (!emailSent)
                    {
                        <p class="text-muted">Введите ваш email адрес, и мы отправим вам ссылку для восстановления пароля.</p>
                        
                        <EditForm Model="@forgotPasswordModel" OnValidSubmit="@HandleForgotPassword" FormName="forgotPasswordForm">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="text-danger" />
                            
                            <div class="mb-3">
                                <label class="form-label">Email <span class="text-danger">*</span></label>
                                <InputText type="email" @bind-Value="forgotPasswordModel.Email" class="form-control" />
                                <ValidationMessage For="@(() => forgotPasswordModel.Email)" />
                            </div>
                            
                            <button type="submit" class="btn btn-primary w-100" disabled="@isProcessing">
                                @if (isProcessing)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                }
                                Отправить ссылку для восстановления
                            </button>
                        </EditForm>
                        
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger mt-3">@errorMessage</div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-success">
                            <h5>Инструкции отправлены!</h5>
                            <p>Если аккаунт с email <strong>@forgotPasswordModel.Email</strong> существует, мы отправили вам ссылку для восстановления пароля.</p>
                            <p class="mb-0">Проверьте вашу почту и следуйте инструкциям.</p>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(resetToken))
                        {
                            <div class="alert alert-info mt-3">
                                <h6>Для разработки (токен восстановления):</h6>
                                <p class="small mb-2">Используйте эту ссылку для сброса пароля:</p>
                                <div class="input-group">
                                    <input type="text" class="form-control" value="@resetLink" readonly id="resetLink" />
                                    <button class="btn btn-outline-secondary" type="button" onclick="copyResetLink()">Копировать</button>
                                </div>
                                <p class="small text-muted mt-2">В продакшене эта ссылка будет отправлена на email.</p>
                            </div>
                        }
                        
                        <div class="text-center mt-3">
                            <a href="/Login" class="btn btn-link">Вернуться к входу</a>
                        </div>
                    }
                    
                    <div class="text-center mt-3">
                        <a href="/Login">Вернуться к входу</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private ForgotPasswordModel forgotPasswordModel = new();
    private string? errorMessage;
    private bool emailSent = false;
    private bool isProcessing = false;
    private string? resetToken;
    private string? resetLink;

    protected override async Task OnInitializedAsync()
    {
        // Проверяем, не авторизован ли уже пользователь
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/", forceLoad: false);
        }
    }

    private async Task HandleForgotPassword()
    {
        errorMessage = null;
        isProcessing = true;

        try
        {
            var user = await UserManager.FindByEmailAsync(forgotPasswordModel.Email);
            
            // Для безопасности всегда показываем успех, даже если пользователь не найден
            if (user != null)
            {
                // Генерируем токен для сброса пароля
                resetToken = await UserManager.GeneratePasswordResetTokenAsync(user);
                
                // Кодируем токен для URL
                var encodedToken = Uri.EscapeDataString(resetToken);
                
                // Формируем ссылку для сброса пароля
                var baseUrl = Navigation.BaseUri.TrimEnd('/');
                resetLink = $"{baseUrl}/ResetPassword?email={forgotPasswordModel.Email}&token={encodedToken}";
                
                // Отправка email (в режиме разработки выводится в логи)
                await EmailSender.SendPasswordResetEmailAsync(user.Email!, resetLink);
                
                // Для разработки просто показываем ссылку на странице
            }
            
            emailSent = true;
        }
        catch (Exception ex)
        {
            errorMessage = $"Ошибка: {ex.Message}";
        }
        finally
        {
            isProcessing = false;
        }
    }

    private class ForgotPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email обязателен")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Некорректный email адрес")]
        public string Email { get; set; } = string.Empty;
    }
}

<script>
    function copyResetLink() {
        var input = document.getElementById('resetLink');
        input.select();
        input.setSelectionRange(0, 99999); // Для мобильных устройств
        document.execCommand('copy');
        alert('Ссылка скопирована в буфер обмена!');
    }
</script>
