@page "/products"
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using OrgTechRepair.Models
@using OrgTechRepair.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Hosting
@attribute [Authorize(Roles = "Manager,Director,Administrator")]
@inject IDbContextFactory<ApplicationDbContext> DbContextFactory
@inject NavigationManager Navigation
@inject IWebHostEnvironment Env

<PageTitle>Товары</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Товары на складе</h2>
        <button class="btn btn-primary" @onclick="CreateNew">Добавить товар</button>
    </div>

    @if (products == null)
    {
        <p>Загрузка...</p>
    }
    else
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4 g-4">
            @foreach (var product in products)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 product-card">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <div class="ratio ratio-4x3 bg-light">
                                <img src="@GetImageSrc(product.ImageUrl)" class="card-img-top object-fit-cover rounded-top" alt="@product.Name" loading="lazy" />
                            </div>
                        }
                        else
                        {
                            <div class="ratio ratio-4x3 bg-light d-flex align-items-center justify-content-center rounded-top">
                                <span class="text-muted small">Нет фото</span>
                            </div>
                        }
                        <div class="card-body d-flex flex-column">
                            <div class="small text-muted">@product.Code</div>
                            <h5 class="card-title fs-6 mt-1">@product.Name</h5>
                            <p class="card-text small text-muted mb-2">@(product.Model ?? "—")</p>
                            <div class="mt-auto">
                                <div class="d-flex justify-content-between align-items-baseline mb-2">
                                    <span class="fw-semibold text-primary">@product.Price.ToString("N2") ₽</span>
                                    <span class="badge bg-secondary">Остаток: @product.Quantity</span>
                                </div>
                                <div class="small text-muted mb-3">@product.Supplier?.Name</div>
                                <div class="d-flex gap-2 flex-wrap">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="() => EditProduct(product.Id)">Изменить</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteProduct(product.Id)">Удалить</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<Product>? products;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        using var context = await DbContextFactory.CreateDbContextAsync();
        products = await context.Products
            .Include(p => p.Supplier)
            .OrderBy(p => p.Name)
            .ToListAsync();
    }

    private string GetImageSrc(string relative)
    {
        if (relative.StartsWith("http", StringComparison.OrdinalIgnoreCase)) return relative;
        return Navigation.ToAbsoluteUri(relative).AbsoluteUri;
    }

    private void CreateNew()
    {
        Navigation.NavigateTo("/products/create");
    }

    private void EditProduct(int id)
    {
        Navigation.NavigateTo($"/products/edit/{id}");
    }

    private async Task DeleteProduct(int id)
    {
        using var context = await DbContextFactory.CreateDbContextAsync();
        var product = await context.Products.FindAsync(id);
        if (product != null)
        {
            if (!string.IsNullOrEmpty(product.ImageUrl) && product.ImageUrl.StartsWith("/uploads/products/", StringComparison.OrdinalIgnoreCase))
            {
                var relative = product.ImageUrl.TrimStart('/').Replace('/', Path.DirectorySeparatorChar);
                var full = Path.Combine(Env.WebRootPath, relative);
                try { if (File.Exists(full)) File.Delete(full); } catch { }
            }
            context.Products.Remove(product);
            await context.SaveChangesAsync();
            await LoadProducts();
        }
    }
}
